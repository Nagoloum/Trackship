# =============================================================================
# Supabase
# =============================================================================
# Find these in your Supabase project settings → API.

# Public (safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Private — keep server-side only. Used for public tracking lookups
# (which bypass RLS) and any privileged admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# App URL
# =============================================================================
# Optional: canonical production URL. When set, the receipt QR codes always
# point here (so a QR generated from a Vercel preview still scans correctly
# in production). Leave empty to use the request origin.
NEXT_PUBLIC_APP_URL=https://trackshipp.vercel.app
